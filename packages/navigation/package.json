{
    "name": "@equinor/mad-navigation",
    "description": "Navigation package built on top of React Navigation",
    "version": "0.7.1",
    "author": {
        "name": "Equinor Mobile App Delivery team (MAD)"
    },
    "bugs": "https://github.com/equinor/mad/issues",
    "devDependencies": {
        "@equinor/eslint-config-mad": "workspace:*",
        "@equinor/mad-tsconfig": "workspace:*",
        "@types/jest": "^29.5.14",
        "eslint": "^8.46.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "tsup": "^8.3.5"
    },
    "files": [
        "CODE_OF_CONDUCT.md",
        "LICENSE",
        "CHANGELOG.md",
        "dist"
    ],
    "homepage": "https://github.com/equinor/mad/",
    "keywords": [
        "navigation",
        "react native",
        "react navigation",
        "typescript"
    ],
    "license": "MIT",
    "main": "./dist/index.js",
    "peerDependencies": {
        "@react-navigation/bottom-tabs": "^7.16.1",
        "@react-navigation/elements": "^2.9.19",
        "@react-navigation/native": "^7.2.5",
        "@react-navigation/native-stack": "^7.15.1",
        "@react-navigation/stack": "^7.9.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-native": "~0.83.6"
    },
    "scripts": {
        "build": "tsup-node && echo '\n ⚙️ Generating typescript declarations..' && tsc --project tsconfig.json --emitDeclarationOnly --declaration",
        "clean": "rm -rf node_modules dist .turbo",
        "dev": "tsup-node --watch --clean=false",
        "lint": "eslint src/",
        "test": "jest"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "dependencies": {
        "warn-once": "^0.1.1"
    }
}
